# ============================================
# FRONTEND ENVIRONMENT VARIABLES (Vite)
# ============================================
# Copy this file to .env.local for local development
# For production (Vercel), set these in Vercel dashboard

# Site URLs
VITE_SITE_URL=http://localhost:5173
VITE_OAUTH_REDIRECT_BASE_URL=http://localhost:5173

# Google OAuth (optional)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# API Base URL
# Local: http://localhost:3000/api
# Production: https://thecourtyard-api.onrender.com/api
VITE_API_BASE_URL=http://localhost:3000/api

# Email Verification Settings
VITE_REQUIRE_EMAIL_VERIFICATION=false
VITE_EMAIL_VERIFICATION_EXPIRY_MINUTES=15

# ============================================
# BACKEND ENVIRONMENT VARIABLES (Node.js)
# ============================================
# Set these in server/.env for local development
# For production (Render), set in Render dashboard

# Node Environment
NODE_ENV=development
PORT=3000

# Security
JWT_SECRET=your_long_random_string_min_32_chars

# MySQL Database (required)
MYSQL_URL=mysql://user:password@localhost:3306/courtyard
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=courtyard

# Gmail Configuration (for email verification and password reset)
GMAIL_ADMIN_EMAIL=your-admin@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_from_gmail

# Frontend Origin (for CORS)
CLIENT_ORIGIN=http://localhost:5173

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
