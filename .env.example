# ============================================
# FRONTEND ENVIRONMENT VARIABLES (Vite)
# ============================================
# Copy this file to .env.local for local development
# For production (Vercel), set these in Vercel dashboard

# Firebase Configuration (get from Firebase Console → Project Settings)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Site URLs
VITE_SITE_URL=http://localhost:5173
VITE_OAUTH_REDIRECT_BASE_URL=http://localhost:5173

# Google OAuth (for Sign-In with Google)
# Get this from Google Cloud Console → Credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# API Base URL
# Local: http://localhost:3000/api
# Production: https://thecourtyard-api.onrender.com/api
VITE_API_BASE_URL=http://localhost:3000/api

# SQL Database (Supabase/Postgres)
# Set USE_SQL_DATABASE=true to use the SQL backend instead of Firebase
USE_SQL_DATABASE=true
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# MySQL Database
# Set USE_MYSQL_DATABASE=true to use MySQL instead of Firebase/Supabase
USE_MYSQL_DATABASE=false
MYSQL_URL=mysql://user:password@localhost:3306/courtyard
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=courtyard

# Email Verification Settings
VITE_REQUIRE_EMAIL_VERIFICATION=false
VITE_EMAIL_VERIFICATION_EXPIRY_MINUTES=15

# ============================================
# BACKEND ENVIRONMENT VARIABLES (Node.js)
# ============================================
# Set these in server/.env for local development
# For production (Render), set in Render dashboard

# Node Environment
NODE_ENV=development
PORT=3000

# Firebase Service Account
# Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key_from_service_account
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your_bucket.appspot.com

# Security
JWT_SECRET=your_long_random_string_min_32_chars

# Gmail Configuration (for email verification)
GMAIL_ADMIN_EMAIL=your-admin@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_from_gmail

# Frontend Origin (for CORS)
CLIENT_ORIGIN=http://localhost:5173

# Supabase Configuration (optional)
# If you use the SQL backend, keep these aligned with the variables above.
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Cloudinary Configuration (for image uploads)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

