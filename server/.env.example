PORT=3000
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=tcy_token
CLIENT_ORIGIN=https://yourdomain.com
NODE_ENV=production

# MySQL database (required)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=courtyard
# Or use a single connection URL instead:
# MYSQL_URL=mysql://user:password@host:3306/courtyard

# Cloudinary upload credentials for gallery images
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=courtyard/gallery

# Optional: seed an admin login user on server startup
ADMIN_SEED_EMAIL=admin@yourdomain.com
ADMIN_SEED_PASSWORD=ChangeThisAdminPass123!
ADMIN_SEED_NAME=Platform Admin

# Gmail SMTP Configuration (for email verification and password reset)
GMAIL_ADMIN_EMAIL=hecourtyardofficial@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# Email Verification Settings
EMAIL_VERIFICATION_EXPIRY_MINUTES=15
